# Copy to .env and fill in passwords.
# .env is gitignored and will be picked up automatically by docker compose.

MARIADB_ROOT_PASSWORD=change_me
MARIADB_PASSWORD=change_me
MARIADB_DATABASE=omeka
MARIADB_USER=omeka
MARIADB_HOST=mariadb

OMEKA_DB_CONNECTION_URL=mysql://${MARIADB_USER}:${MARIADB_PASSWORD}@${MARIADB_HOST}/${MARIADB_DATABASE}

# Omeka S API credentials (create in admin: User > API Keys)
# Used by seed.py to populate sample data
OMEKA_KEY_IDENTITY=
OMEKA_KEY_CREDENTIAL=
