<?php
/**
 * Site page template.
 * If the page uses the "homepage" template, render our custom home layout.
 * Otherwise, render standard editorial page content.
 */
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');
$thumbnail = $this->plugin('thumbnail');

$this->headLink()->appendStylesheet($this->assetUrl('css/page-blocks.css', 'Omeka'));
$this->htmlElement('body')->appendAttribute('class', $pageBodyClass);

// Check if this is the homepage
$homepage = $site->homepage();
$isHomepage = ($homepage && $page->slug() === $homepage->slug());
?>

<?php if ($isHomepage): ?>
<?php
// Fetch data for the homepage
$api = $this->api();
$recentItems = $api->search('items', ['sort_by' => 'created', 'sort_order' => 'desc', 'limit' => 4, 'site_id' => $site->id()])->getContent();
$itemSets = $api->search('item_sets', ['site_id' => $site->id(), 'limit' => 6])->getContent();
?>

<!-- Hero -->
<section class="hero">
    <div class="container">
        <div class="hero-content">
            <h1><?php echo $escape($this->themeSetting('hero_headline') ?: 'The voices of a town, recorded'); ?></h1>
            <?php $summary = $site->summary(); ?>
            <?php if ($summary): ?>
            <p class="body-large"><?php echo $escape($summary); ?></p>
            <?php endif; ?>
            <div class="hero-buttons">
                <a href="<?php echo $this->url('site/resource', ['controller' => 'item', 'action' => 'browse'], true); ?>" class="btn btn-primary"><?php echo $translate('Browse interviews'); ?></a>
            </div>
        </div>
        <div class="hero-image">
            <?php
            // Pick a random item with a thumbnail for the hero
            $allItems = $api->search('items', ['site_id' => $site->id(), 'limit' => 50])->getContent();
            $withThumbs = array_filter($allItems, function($i) { return $i->primaryMedia() && $i->primaryMedia()->hasThumbnails(); });
            $heroItem = null;
            if (!empty($withThumbs)) {
                $heroItem = $withThumbs[array_rand($withThumbs)];
            }
            ?>
            <?php if ($heroItem): ?>
            <a href="<?php echo $escape($heroItem->siteUrl($site->slug())); ?>" class="hero-image-link">
                <?php echo $thumbnail($heroItem->primaryMedia(), 'large'); ?>
                <span class="hero-image-caption"><?php echo $escape($heroItem->displayTitle()); ?></span>
            </a>
            <?php else: ?>
            <div class="hero-image-placeholder">
                <?php echo $translate('Hero photograph'); ?>
            </div>
            <?php endif; ?>
        </div>
    </div>
</section>

<?php if ($this->content): ?>
<!-- Page blocks (admin content) -->
<section class="section">
    <div class="container">
        <div class="editorial">
            <?php echo $this->content; ?>
        </div>
    </div>
</section>
<?php endif; ?>

<?php if (count($recentItems) > 0): ?>
<!-- Recently Added -->
<section class="section" style="background: var(--accent-soft);">
    <div class="container">
        <div class="section-header">
            <div class="kicker"><?php echo $translate('Recently Added'); ?></div>
            <h2><?php echo $translate('New to the archive'); ?></h2>
        </div>
        <div class="grid-4">
            <?php foreach ($recentItems as $item): ?>
            <a href="<?php echo $escape($item->siteUrl($site->slug())); ?>" class="card">
                <?php $media = $item->primaryMedia(); ?>
                <?php if ($media && $media->hasThumbnails()): ?>
                <div class="card-thumb">
                    <?php echo $thumbnail($media, 'medium'); ?>
                </div>
                <?php endif; ?>
                <div class="card-body">
                    <?php
                    $sets = $item->itemSets();
                    if (count($sets)):
                        $firstSet = current($sets);
                    ?>
                    <div class="kicker"><?php echo $escape($firstSet->displayTitle()); ?></div>
                    <?php endif; ?>
                    <h3><?php echo $escape($item->displayTitle()); ?></h3>
                    <?php $desc = $item->value('dcterms:description'); ?>
                    <?php if ($desc): ?>
                    <p><?php echo $escape($desc); ?></p>
                    <?php endif; ?>
                </div>
            </a>
            <?php endforeach; ?>
        </div>
    </div>
</section>
<?php endif; ?>

<?php if (count($itemSets) > 0): ?>
<!-- Collections -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <div class="kicker"><?php echo $translate('Collections'); ?></div>
            <h2><?php echo $translate('Explore by theme'); ?></h2>
        </div>
        <div class="grid-3">
            <?php foreach ($itemSets as $itemSet): ?>
            <a href="<?php echo $escape($itemSet->siteUrl($site->slug())); ?>" class="card card-item-set">
                <div class="card-body">
                    <?php $date = $itemSet->value('dcterms:date'); ?>
                    <?php if ($date): ?>
                    <div class="meta"><?php echo $escape($date); ?></div>
                    <?php endif; ?>
                    <h3><?php echo $escape($itemSet->displayTitle()); ?></h3>
                    <?php $desc = $itemSet->value('dcterms:description'); ?>
                    <?php if ($desc): ?>
                    <p><?php echo $escape($desc); ?></p>
                    <?php endif; ?>
                </div>
            </a>
            <?php endforeach; ?>
        </div>
    </div>
</section>
<?php endif; ?>

<?php else: ?>
<?php // ---------- Standard page ---------- ?>

<?php $this->headTitle($page->title()); ?>

<!-- Subpage Hero -->
<section class="subpage-hero">
    <div class="container">
        <h1><?php echo $escape($page->title()); ?></h1>
    </div>
</section>

<!-- Page Content -->
<section class="section">
    <div class="container">
        <div class="editorial">
            <?php $this->trigger('view.show.before'); ?>
            <div class="blocks">
                <?php echo $this->content; ?>
            </div>
            <?php $this->trigger('view.show.after'); ?>
        </div>
    </div>
</section>

<?php
// Find child pages from the site navigation
$childPages = [];
$navData = $site->navigation();

// Recursive search for the current page's children in the nav tree
$findChildren = function ($items, $pageId) use (&$findChildren) {
    foreach ($items as $item) {
        $type = $item['type'] ?? '';
        $id = $item['data']['id'] ?? null;
        if ($type === 'page' && $id == $pageId) {
            return $item['links'] ?? [];
        }
        if (!empty($item['links'])) {
            $result = $findChildren($item['links'], $pageId);
            if ($result) return $result;
        }
    }
    return [];
};

$navChildren = $findChildren($navData, $page->id());

if (!empty($navChildren)):
    $api = $this->api();
    $siteSlug = $site->slug();
    $sitePages = $api->search('site_pages', ['site_id' => $site->id()])->getContent();
    $pageLookup = [];
    foreach ($sitePages as $sp) {
        $pageLookup[$sp->id()] = $sp;
    }
    foreach ($navChildren as $child) {
        if (($child['type'] ?? '') === 'page' && isset($child['data']['id'])) {
            $childId = $child['data']['id'];
            if (isset($pageLookup[$childId])) {
                $childPages[] = $pageLookup[$childId];
            }
        }
    }
?>

<?php if (!empty($childPages)): ?>
<section class="section">
    <div class="container">
        <div class="child-pages">
            <?php foreach ($childPages as $childPage):
                // Try to find a thumbnail from the page's media block
                $childThumb = null;
                $childSnippet = '';
                $childBlocks = $childPage->blocks();
                foreach ($childBlocks as $block) {
                    $layout = $block->layout();
                    if (!$childThumb && ($layout === 'media' || $layout === 'mediaEmbed')) {
                        $attachments = $block->attachments();
                        foreach ($attachments as $att) {
                            $media = $att->media();
                            if ($media && $media->hasThumbnails()) {
                                $childThumb = $media;
                                break;
                            }
                            $attItem = $att->item();
                            if (!$childThumb && $attItem && $attItem->thumbnail()) {
                                $childThumb = $attItem;
                                break;
                            }
                        }
                    }
                    if (!$childSnippet && $layout === 'html') {
                        $blockData = $block->dataValue('html');
                        if ($blockData) {
                            $text = strip_tags($blockData);
                            $childSnippet = mb_substr($text, 0, 200);
                            if (mb_strlen($text) > 200) $childSnippet .= '…';
                        }
                    }
                }
            ?>
            <a href="<?php echo $escape($childPage->siteUrl($site->slug())); ?>" class="child-page-card">
                <?php if ($childThumb): ?>
                <div class="child-page-thumb">
                    <?php echo $thumbnail($childThumb, 'medium'); ?>
                </div>
                <?php endif; ?>
                <div class="child-page-body">
                    <h3><?php echo $escape($childPage->title()); ?></h3>
                    <?php if ($childSnippet): ?>
                    <p><?php echo $escape($childSnippet); ?></p>
                    <?php endif; ?>
                    <span class="child-page-link"><?php echo $translate('Read more'); ?> →</span>
                </div>
            </a>
            <?php endforeach; ?>
        </div>
    </div>
</section>
<?php endif; ?>

<?php endif; ?>

<?php endif; ?>
