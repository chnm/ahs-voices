<?php
/**
 * Home page — fallback when no pages are configured.
 * In practice, Omeka S serves the homepage via page/show.phtml
 * using the homepage page template. This is the fallback.
 */
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');
$thumbnail = $this->plugin('thumbnail');

// Fetch recent items
$api = $this->api();
$recentItems = $api->search('items', ['sort_by' => 'created', 'sort_order' => 'desc', 'limit' => 4, 'site_id' => $site->id()])->getContent();
$itemSets = $api->search('item_sets', ['site_id' => $site->id(), 'limit' => 6])->getContent();
?>

<!-- Hero -->
<section class="hero">
    <div class="container">
        <div class="hero-content">
            <h1><?php echo $escape($this->themeSetting('hero_headline') ?: 'The voices of a town, recorded'); ?></h1>
            <?php $summary = $site->summary(); ?>
            <?php if ($summary): ?>
            <p class="body-large"><?php echo $escape($summary); ?></p>
            <?php endif; ?>
            <?php
            $btn1Text = $this->themeSetting('hero_button1_text');
            $btn1Url = $this->themeSetting('hero_button1_url') ?: $this->url('site/resource', ['controller' => 'item', 'action' => 'browse'], true);
            $btn2Text = $this->themeSetting('hero_button2_text');
            $btn2Url = $this->themeSetting('hero_button2_url');
            if ($btn1Text || $btn2Text):
            ?>
            <div class="hero-buttons">
                <?php if ($btn1Text): ?>
                <a href="<?php echo $escape($btn1Url); ?>" class="btn btn-primary"><?php echo $escape($btn1Text); ?> →</a>
                <?php endif; ?>
                <?php if ($btn2Text && $btn2Url): ?>
                <a href="<?php echo $escape($btn2Url); ?>" class="btn btn-ghost"><?php echo $escape($btn2Text); ?></a>
                <?php endif; ?>
            </div>
            <?php endif; ?>
        </div>
        <div class="hero-image">
            <?php
            $allItems = $api->search('items', ['site_id' => $site->id(), 'limit' => 50])->getContent();
            $withThumbs = array_filter($allItems, function($i) { return $i->primaryMedia() && $i->primaryMedia()->hasThumbnails(); });
            $heroItem = null;
            if (!empty($withThumbs)) {
                $heroItem = $withThumbs[array_rand($withThumbs)];
            }
            ?>
            <?php if ($heroItem): ?>
            <a href="<?php echo $escape($heroItem->siteUrl($site->slug())); ?>" class="hero-image-link">
                <?php echo $thumbnail($heroItem->primaryMedia(), 'large'); ?>
                <span class="hero-image-caption"><?php echo $escape($heroItem->displayTitle()); ?></span>
            </a>
            <?php else: ?>
            <?php
            $fallbackHeroImages = [
                'arlingtonhouseearly20thcentlocpublic_720.jpg',
                'HenryGray1005SQuinnArlingtonViewClark.jpg',
                'QueenCity__1564066687530__w1920.jpg',
                'WalkerBrick__1564067733927__w1920.jpg',
            ];
            $fallback = $fallbackHeroImages[array_rand($fallbackHeroImages)];
            ?>
            <img src="<?php echo $this->assetUrl('img/hero/' . $fallback); ?>" alt="" />
            <?php endif; ?>
        </div>
    </div>
</section>

<?php if (count($recentItems) > 0): ?>
<!-- Recently Added -->
<section class="section" style="background: var(--accent-soft);">
    <div class="container">
        <div class="section-header">
            <div class="kicker"><?php echo $translate('Recently Added'); ?></div>
            <h2><?php echo $translate('New to the archive'); ?></h2>
        </div>
        <div class="grid-4">
            <?php foreach ($recentItems as $item): ?>
            <a href="<?php echo $escape($item->siteUrl($site->slug())); ?>" class="card">
                <?php if ($item->thumbnail()):?>
                <div class="card-thumb">
                    <?php echo $thumbnail($item, 'medium'); ?>
                </div>
                <?php endif; ?>
                <div class="card-body">
                    <?php
                    $sets = $item->itemSets();
                    if (count($sets)):
                        $firstSet = current($sets);
                    ?>
                    <div class="kicker"><?php echo $escape($firstSet->displayTitle()); ?></div>
                    <?php endif; ?>
                    <h3><?php echo $escape($item->displayTitle()); ?></h3>
                    <?php $desc = $item->value('dcterms:description'); ?>
                    <?php if ($desc): ?>
                    <p><?php echo $escape(mb_substr($desc, 0, 120) . (mb_strlen($desc) > 120 ? '…' : '')); ?></p>
                    <?php endif; ?>
                </div>
            </a>
            <?php endforeach; ?>
        </div>
    </div>
</section>
<?php endif; ?>

<?php if (count($itemSets) > 0): ?>
<!-- Collections -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <div class="kicker"><?php echo $translate('Collections'); ?></div>
            <h2><?php echo $translate('Explore by theme'); ?></h2>
        </div>
        <div class="grid-3">
            <?php foreach ($itemSets as $itemSet): ?>
            <a href="<?php echo $escape($itemSet->siteUrl($site->slug())); ?>" class="card card-item-set">
                <div class="card-body">
                    <?php $date = $itemSet->value('dcterms:date'); ?>
                    <?php if ($date): ?>
                    <div class="meta"><?php echo $escape($date); ?></div>
                    <?php endif; ?>
                    <h3><?php echo $escape($itemSet->displayTitle()); ?></h3>
                    <?php $desc = $itemSet->value('dcterms:description'); ?>
                    <?php if ($desc): ?>
                    <p><?php echo $escape($desc); ?></p>
                    <?php endif; ?>
                </div>
            </a>
            <?php endforeach; ?>
        </div>
    </div>
</section>
<?php endif; ?>
